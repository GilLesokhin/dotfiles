// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  // Agents
  "agent": {
    "sidebar_side": "right",
    "dock": "right",
    "default_model": {
      "provider": "google",
      "model": "gemini-2.5-flash"
    },
    "thread_summary_model": {
      "provider": "google",
      "model": "gemini-2.5-flash"
    }
  },

  // Panel
  "collaboration_panel": { "dock": "left", "button": false },
  "project_panel": { "dock": "left", "hide_root": true },
  "outline_panel": { "dock": "left" },
  "git_panel": { "dock": "left" },
  //"git": { "inline_blame": { "enabled": false } },

  "telemetry": { "diagnostics": false, "metrics": false },

  // Fonts
  "tab_size": 2,
  "ui_font_size": 18,
  "buffer_font_family": "RobotoMono Nerd Font",
  "buffer_font_size": 16,
  "agent_ui_font_size": 16,
  "agent_buffer_font_size": 14,
  "terminal": {
    "font_family": "RobotoMono Nerd Font",
    "font_size": 16,
    "cursor_shape": "bar"
  },

  // Themes
  "theme": "Catppuccin Mocha - No Italics",
  "icon_theme": "Catppuccin Mocha",
  "theme_overrides": {
    "Kanagawa Wave - No Italics": {
      "text.muted": "#DCD7BAB0",
      "border.variant": "#DCD7BAB0",
      "syntax": {
        "punctuation": { "color": "#8a8980" },
        "punctuation.bracket": { "color": "#8a8980" },
        "punctuation.special": { "color": "#8a8980" },
        "punctuation.list_marker": { "color": "#8a8980" }
      }
    }
  }
}
